{
    "openapi": "3.0.0",
    "info": {
        "title": "ConvoPilot Multi-Tenant API",
        "description": "This API provides a secure, multi-tenant platform for managing AI chatbots and conversations.",
        "version": "1.0.0",
        "contact": {
            "name": "ConvoPilot Support",
            "url": "https://convopilot.com/support",
            "email": "support@convopilot.com"
        },
        "license": {
            "name": "Proprietary",
            "url": "https://convopilot.com/license"
        }
    },
    "servers": [
        {
            "url": "http://127.0.0.1:5001/api/v1",
            "description": "Development server"
        }
    ],
    "components": {
        "securitySchemes": {
            "Bearer": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "JWT token in the format: Bearer <token>"
            },
            "TenantID": {
                "type": "apiKey",
                "name": "X-Tenant-ID",
                "in": "header",
                "description": "Tenant ID for multi-tenant requests"
            }
        }
    },
    "security": [
        {
            "Bearer": [],
            "TenantID": []
        }
    ],
    "tags": [
        {
            "name": "Authentication",
            "description": "User authentication and token management"
        },
        {
            "name": "Tenants",
            "description": "Tenant management operations"
        },
        {
            "name": "Users",
            "description": "User management within tenants"
        },
        {
            "name": "Chatbots",
            "description": "Chatbot configuration and management"
        },
        {
            "name": "Chatbot Management",
            "description": "Full CRUD operations for chatbot configuration and management (Sprint 2)"
        },
        {
            "name": "Data Sources",
            "description": "Secure file uploads, web crawling, and data source management for chatbot training (Sprint 2)"
        },
        {
            "name": "Usage & Analytics",
            "description": "Token usage tracking, cost analytics, and usage reporting (Sprint 2)"
        },
        {
            "name": "Conversations",
            "description": "Chat history and conversation management"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "tags": ["Authentication"],
                "summary": "Login user",
                "description": "Authenticate user and return JWT token",
                "security": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["email", "password"],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "integer"
                                                },
                                                "email": {
                                                    "type": "string"
                                                },
                                                "role": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/auth/signup": {
            "post": {
                "tags": ["Authentication"],
                "summary": "Register new admin user",
                "description": "Create a new administrator account",
                "security": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["email", "password", "firstName", "lastName"],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "minLength": 8
                                    },
                                    "firstName": {
                                        "type": "string"
                                    },
                                    "lastName": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Account created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "integer"
                                                },
                                                "email": {
                                                    "type": "string"
                                                },
                                                "role": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid input"
                    },
                    "409": {
                        "description": "Email already exists"
                    }
                }
            }
        },
        "/auth/confirm-email/{token}": {
            "get": {
                "tags": ["Authentication"],
                "summary": "Confirm email address",
                "description": "Verify email address using confirmation token",
                "security": [],
                "parameters": [
                    {
                        "name": "token",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Email confirmed successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "integer"
                                                },
                                                "email": {
                                                    "type": "string"
                                                },
                                                "role": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid or expired token"
                    }
                }
            }
        }
    }
}
